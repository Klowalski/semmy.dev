---
import BaseLayout from '../layouts/BaseLayout.astro';

---

<BaseLayout>
  <!-- Hero -->
  <section style="max-width:1100px; margin:0 auto; padding:100px 24px 80px;">
    <div class="fade-in" style="margin-bottom:20px; display:inline-flex; align-items:center; gap:8px; background:rgba(34,211,238,0.08); border:1px solid rgba(34,211,238,0.2); border-radius:100px; padding:6px 14px;">
      <span class="pulse-dot" style="width:7px; height:7px; border-radius:50%; background:#22d3ee; display:inline-block;"></span>
      <span style="font-size:0.8rem; color:#22d3ee; font-family:'JetBrains Mono',monospace; letter-spacing:0.04em;">building in public · Ukraine 🇺🇦</span>
    </div>
    
    <h1 class="fade-in-delay-1" style="font-size:clamp(3rem, 8vw, 5.5rem); font-weight:900; line-height:1.05; letter-spacing:-0.03em; margin-bottom:24px;">
      <span class="gradient-text">Daniel</span><br/>
      <span style="color:#f1f5f9;">Petrushevsky</span>
    </h1>
    
    <p class="fade-in-delay-2" style="font-size:clamp(1.1rem, 2.5vw, 1.4rem); color:#64748b; max-width:580px; margin-bottom:40px; line-height:1.6;">
      Gamer. Builder. Chaos enjoyer.<br/>
      <span style="color:#94a3b8;">Ships tools from Ukraine, breaks things for fun, fixes them for money.</span>
    </p>
    
    <div class="fade-in-delay-3" style="display:flex; gap:16px; flex-wrap:wrap;">
      <a href="https://github.com/SeMmyT" target="_blank" rel="noopener"
         style="display:inline-flex; align-items:center; gap:8px; padding:12px 24px; background:#22d3ee; color:#080810; border-radius:10px; font-weight:700; font-size:0.95rem; text-decoration:none; transition:all 0.2s; letter-spacing:-0.01em;"
         onmouseover="this.style.background='#67e8f9'; this.style.transform='translateY(-1px)'"
         onmouseout="this.style.background='#22d3ee'; this.style.transform='translateY(0)'">
        GitHub
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
      </a>
      <a href="/blog"
         style="display:inline-flex; align-items:center; gap:8px; padding:12px 24px; border:1px solid rgba(255,255,255,0.12); color:#94a3b8; border-radius:10px; font-weight:600; font-size:0.95rem; text-decoration:none; transition:all 0.2s;"
         onmouseover="this.style.borderColor='rgba(34,211,238,0.4)'; this.style.color='#22d3ee'; this.style.transform='translateY(-1px)'"
         onmouseout="this.style.borderColor='rgba(255,255,255,0.12)'; this.style.color='#94a3b8'; this.style.transform='translateY(0)'">
        Read Blog
      </a>
    </div>
  </section>

  <!-- Stats bar -->
  <section style="max-width:1100px; margin:0 auto; padding:0 24px 80px;">
    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(160px, 1fr)); gap:1px; background:rgba(255,255,255,0.06); border-radius:16px; overflow:hidden;">
      {[
        { label: 'Projects shipped', value: '10+' },
        { label: 'Years building', value: '5+' },
        { label: 'Coffee consumed', value: '∞' },
        { label: 'Stack preference', value: 'TypeScript' },
      ].map(stat => (
        <div style="background:#080810; padding:24px 28px; transition:background 0.2s;"
             onmouseover="this.style.background='rgba(34,211,238,0.03)'"
             onmouseout="this.style.background='#080810'">
          <div style="font-size:1.6rem; font-weight:800; color:#f1f5f9; letter-spacing:-0.02em; margin-bottom:4px;">{stat.value}</div>
          <div style="font-size:0.8rem; color:#475569; font-family:'JetBrains Mono',monospace;">{stat.label}</div>
        </div>
      ))}
    </div>
  </section>


  <!-- Connect CTA -->
  <section style="max-width:1100px; margin:0 auto; padding:0 24px 100px;">
    <div style="text-align:center; padding:64px 40px; background:rgba(34,211,238,0.03); border:1px solid rgba(34,211,238,0.1); border-radius:24px; position:relative; overflow:hidden;">
      <div style="position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:400px; height:200px; background:radial-gradient(ellipse, rgba(34,211,238,0.06) 0%, transparent 70%); pointer-events:none;"></div>
      <h2 style="font-size:2rem; font-weight:800; letter-spacing:-0.03em; color:#f1f5f9; margin-bottom:12px;">Let's build something.</h2>
      <p style="color:#64748b; margin-bottom:32px; font-size:1rem;">Open to interesting projects, collaborations, and conversations.</p>
      <div style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap;">
        <a href="https://github.com/SeMmyT" target="_blank" rel="noopener"
           style="padding:12px 28px; background:#22d3ee; color:#080810; border-radius:10px; font-weight:700; text-decoration:none; font-size:0.95rem; transition:all 0.2s;"
           onmouseover="this.style.background='#67e8f9'; this.style.transform='translateY(-1px)'"
           onmouseout="this.style.background='#22d3ee'; this.style.transform='translateY(0)'">
          GitHub
        </a>
        <a href="https://www.linkedin.com/in/daniel-signalhire/" target="_blank" rel="noopener"
           style="padding:12px 28px; border:1px solid rgba(255,255,255,0.1); color:#94a3b8; border-radius:10px; font-weight:600; text-decoration:none; font-size:0.95rem; transition:all 0.2s;"
           onmouseover="this.style.borderColor='rgba(34,211,238,0.4)'; this.style.color='#22d3ee'; this.style.transform='translateY(-1px)'"
           onmouseout="this.style.borderColor='rgba(255,255,255,0.1)'; this.style.color='#94a3b8'; this.style.transform='translateY(0)'">
          LinkedIn
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
